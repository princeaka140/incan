# GCD Benchmark
# Compute GCD for many number pairs using std.math.gcd

import std.math

def main() -> None:
    iterations = 10_000_000
    mut total = 0
    
    # Deterministic pairs based on loop index
    for i in range(1, iterations + 1):
        a = (i * 17) % 10000 + 1
        b = (i * 31) % 10000 + 1
        total += math.gcd(a, b)
    
    println(f"Sum of {iterations} GCDs: {total}")
