    def finalize_u128(mut self) -> u128:
        return self.handle.digest128()


@rust.allow("non_camel_case_types")
pub class sha224:
    """
    SHA-224 namespace with one-shot and incremental hashing.
    """

    @staticmethod
    def digest(data: bytes) -> bytes:
        return _must_digest_bytes(data, "sha224", 0)

    @staticmethod
    def new() -> _Sha224Hasher:
        return _Sha224Hasher(handle=Sha224.default())


