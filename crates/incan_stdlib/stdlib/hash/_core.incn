pub class _Shake128Hasher with ShakeDigestHasher:
    """
    Incremental SHAKE128 hasher with explicit output length.
    """

    handle: Shake128

    def update(mut self, chunk: bytes) -> None:
        Update.update(self.handle, chunk.as_slice())

    def finalize_bytes(mut self, length: int) -> Result[bytes, HashError]:
        if length <= 0:
            return Err(_invalid_error("shake128", "invalid_length", "SHAKE digest length must be positive"))
        mut out = _zeros(length)
        mut reader = ExtendableOutputReset.finalize_xof_reset(self.handle)
        reader.read(out)
        return Ok(out)


pub class _Shake256Hasher with ShakeDigestHasher:
    """
    Incremental SHAKE256 hasher with explicit output length.
    """

    handle: Shake256

    def update(mut self, chunk: bytes) -> None:
        Update.update(self.handle, chunk.as_slice())

    def finalize_bytes(mut self, length: int) -> Result[bytes, HashError]:
        if length <= 0:
            return Err(_invalid_error("shake256", "invalid_length", "SHAKE digest length must be positive"))
        mut out = _zeros(length)
        mut reader = ExtendableOutputReset.finalize_xof_reset(self.handle)
        reader.read(out)
        return Ok(out)


