def _digest_bytes(data: bytes, algorithm: str, length: int) -> Result[bytes, HashError]:
    """
    Parse a public algorithm name and compute one-shot digest bytes.
    """
    return _digest_algorithm(data, _Algorithm.from_str(algorithm)?, length)


def _digest_algorithm(data: bytes, algorithm: _Algorithm, length: int) -> Result[bytes, HashError]:
    """
    Dispatch one-shot byte hashing after algorithm validation.

    SHAKE algorithms validate caller-selected output length here because fixed-size digest algorithms ignore the
    `length` argument by design.
    """
    match algorithm:
        _Algorithm.Sha224 => return _digest_from_hasher(sha224.new(), data)
        _Algorithm.Sha256 => return _digest_from_hasher(sha256.new(), data)
        _Algorithm.Sha384 => return _digest_from_hasher(sha384.new(), data)
        _Algorithm.Sha512 => return _digest_from_hasher(sha512.new(), data)
        _Algorithm.Sha3_224 => return _digest_from_hasher(sha3_224.new(), data)
        _Algorithm.Sha3_256 => return _digest_from_hasher(sha3_256.new(), data)
        _Algorithm.Sha3_384 => return _digest_from_hasher(sha3_384.new(), data)
        _Algorithm.Sha3_512 => return _digest_from_hasher(sha3_512.new(), data)
        _Algorithm.Shake128 =>
            if length <= 0:
                return Err(_invalid_error(algorithm.name(), "invalid_length", "SHAKE digest length must be positive"))
            mut hasher = shake128.new()
            hasher.update(data)
            return hasher.finalize_bytes(length)
        _Algorithm.Shake256 =>
            if length <= 0:
                return Err(_invalid_error(algorithm.name(), "invalid_length", "SHAKE digest length must be positive"))
            mut hasher = shake256.new()
            hasher.update(data)
            return hasher.finalize_bytes(length)
        _Algorithm.Blake2b => return _digest_from_hasher(blake2b.new(), data)
        _Algorithm.Blake2s => return _digest_from_hasher(blake2s.new(), data)
        _Algorithm.Blake3 => return Ok(blake3_hash(data.as_slice()).as_bytes().to_vec())
        _Algorithm.Md5 => return _digest_from_hasher(md5.new(), data)
        _Algorithm.Sha1 => return _digest_from_hasher(sha1.new(), data)
        _Algorithm.Xxh32 => return Ok(_u32_to_le_bytes(_xxh32_hash(data)))
        _Algorithm.Xxh64 => return Ok(_u64_to_le_bytes(_xxh64_hash(data)))
        _Algorithm.Xxh3_64 => return Ok(_u64_to_le_bytes(_xxh3_64_hash(data)))
        _Algorithm.Xxh3_128 => return Ok(_u128_to_le_bytes(_xxh3_128_hash(data)))


def _digest_from_hasher[H with ByteDigestHasher](mut hasher: H, data: bytes) -> Result[bytes, HashError]:
    """
    Feed all bytes into a fixed-length digest hasher and finalize it.
    """
    hasher.update(data)
    return Ok(hasher.finalize_bytes())


def _hash_u32(data: bytes, algorithm: str) -> Result[u32, HashError]:
    """
    Compute a native `u32` hash for algorithms that expose that width.
    """
    match _Algorithm.from_str(algorithm)?:
        _Algorithm.Xxh32 => return Ok(_xxh32_hash(data))
        _ => return Err(_unsupported_width_error(algorithm, "u32"))


def _hash_u64(data: bytes, algorithm: str) -> Result[u64, HashError]:
    """
    Compute a native `u64` hash for algorithms that expose that width.
    """
    match _Algorithm.from_str(algorithm)?:
        _Algorithm.Xxh3_64 => return Ok(_xxh3_64_hash(data))
        _Algorithm.Xxh64 => return Ok(_xxh64_hash(data))
        _ => return Err(_unsupported_width_error(algorithm, "u64"))


def _hash_u128(data: bytes, algorithm: str) -> Result[u128, HashError]:
    """
    Compute a native `u128` hash for algorithms that expose that width.
    """
    match _Algorithm.from_str(algorithm)?:
        _Algorithm.Xxh3_128 => return Ok(_xxh3_128_hash(data))
        _ => return Err(_unsupported_width_error(algorithm, "u128"))


def _xxh32_hash(data: bytes) -> u32:
    """
    Run xxHash32 over one byte payload.
    """
    mut hasher = xxh32.new()
    hasher.update(data)
    return hasher.finalize_u32()


def _xxh64_hash(data: bytes) -> u64:
    """
    Run xxHash64 over one byte payload.
    """
    mut hasher = xxh64.new()
    hasher.update(data)
    return hasher.finalize_u64()


def _xxh3_64_hash(data: bytes) -> u64:
    """
    Run XXH3 with native 64-bit output over one byte payload.
    """
    mut hasher = xxh3_64.new()
    hasher.update(data)
    return hasher.finalize_u64()


def _xxh3_128_hash(data: bytes) -> u128:
    """
    Run XXH3 with native 128-bit output over one byte payload.
    """
    mut hasher = xxh3_128.new()
    hasher.update(data)
    return hasher.finalize_u128()


def _must_digest_bytes(data: bytes, algorithm: str, length: int) -> bytes:
    """
    Return digest bytes or raise `ValueError` for namespace helpers with infallible signatures.
    """
    match _digest_bytes(data, algorithm, length):
        Ok(value) => return value
        Err(err) => return raise_value_error(err.detail)


def _must_hash_u32(data: bytes, algorithm: str) -> u32:
    """
    Return a native `u32` hash or raise `ValueError` for namespace helpers.
    """
    match _hash_u32(data, algorithm):
        Ok(value) => return value
        Err(err) => return raise_value_error(err.detail)


def _must_hash_u64(data: bytes, algorithm: str) -> u64:
    """
    Return a native `u64` hash or raise `ValueError` for namespace helpers.
    """
    match _hash_u64(data, algorithm):
        Ok(value) => return value
        Err(err) => return raise_value_error(err.detail)


def _must_hash_u128(data: bytes, algorithm: str) -> u128:
    """
    Return a native `u128` hash or raise `ValueError` for namespace helpers.
    """
    match _hash_u128(data, algorithm):
        Ok(value) => return value
        Err(err) => return raise_value_error(err.detail)


def _zeros(size: int) -> bytes:
    """
    Allocate a zero-filled byte vector for SHAKE finalization buffers.
    """
    zero: u8 = 0
    return list.repeat(zero, size)


def _u32_to_le_bytes(value: u32) -> bytes:
    """
    Encode a 32-bit integer as little-endian bytes in Incan source.
    """
    number = int(value)
    mut out: list[u8] = []
    _append_byte(out, number % 256)
    _append_byte(out, (number // 256) % 256)
    _append_byte(out, (number // 65536) % 256)
    _append_byte(out, (number // 16777216) % 256)
    return out


def _u64_to_le_bytes(value: u64) -> bytes:
    """
    Encode a 64-bit integer as little-endian bytes in Incan source.
    """
    number = int(value)
    mut out: list[u8] = []
    _append_byte(out, number % 256)
    _append_byte(out, (number // 256) % 256)
    _append_byte(out, (number // 65536) % 256)
    _append_byte(out, (number // 16777216) % 256)
    _append_byte(out, (number // 4294967296) % 256)
    _append_byte(out, (number // 1099511627776) % 256)
    _append_byte(out, (number // 281474976710656) % 256)
    _append_byte(out, (number // 72057594037927936) % 256)
    return out


def _u128_to_le_bytes(value: u128) -> bytes:
    """
    Encode a 128-bit integer as little-endian bytes in Incan source.
    """
    mut out: list[u8] = []
    _append_byte(out, int(value % 256))
    _append_byte(out, int((value // 256) % 256))
    _append_byte(out, int((value // 65536) % 256))
    _append_byte(out, int((value // 16777216) % 256))
    _append_byte(out, int((value // 4294967296) % 256))
    _append_byte(out, int((value // 1099511627776) % 256))
    _append_byte(out, int((value // 281474976710656) % 256))
    _append_byte(out, int((value // 72057594037927936) % 256))
    _append_byte(out, int((value // 18446744073709551616) % 256))
    _append_byte(out, int((value // 4722366482869645213696) % 256))
    _append_byte(out, int((value // 1208925819614629174706176) % 256))
    _append_byte(out, int((value // 309485009821345068724781056) % 256))
    _append_byte(out, int((value // 79228162514264337593543950336) % 256))
    _append_byte(out, int((value // 20282409603651670423947251286016) % 256))
    _append_byte(out, int((value // 5192296858534827628530496329220096) % 256))
    _append_byte(out, int((value // 1329227995784915872903807060280344576) % 256))
    return out


def _append_byte(mut out: list[u8], value: int) -> None:
    """
    Append one low byte after explicit wrapping conversion to `u8`.
    """
    byte: u8 = value.wrapping_resize()
    out.append(byte)


pub def _invalid_error(algorithm: str, kind: str, detail: str) -> HashError:
    """
    Build a validation or capability error for hash helper APIs.
    """
    return HashError(kind=kind, algorithm=algorithm, detail=detail)


pub def _io_error(algorithm: str, kind: str, detail: str) -> HashError:
    """
    Map lower-level reader or filesystem I/O failures into hash-domain errors.
    """
    return HashError(kind=kind, algorithm=algorithm, detail=detail)


pub def _unsupported_width_error(algorithm: str, width: str) -> HashError:
    """
    Distinguish known algorithms with the wrong native integer width from unknown algorithm names.
    """
    if _Algorithm.is_known(algorithm):
        return _invalid_error(algorithm, "unsupported_width", f"{algorithm} does not expose a {width} hash")
    return _invalid_error(algorithm, "unknown_algorithm", f"unknown hash algorithm: {algorithm}")
