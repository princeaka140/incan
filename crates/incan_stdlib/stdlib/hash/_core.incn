"""
Core `std.hash` algorithms and one-shot helpers.

This module owns the algorithm wrappers and value hashing paths. File and reader streaming live in
`std.hash._streaming` so the public prelude stays small and the hot dispatch paths are easier to audit.
"""

from rust::incan_stdlib::errors import raise_value_error
from rust::blake2 @ "0.10" import Blake2b512, Blake2s256
from rust::blake3 @ "1" import Hasher as Blake3Hasher, hash as blake3_hash
from rust::md5 @ "0.10" import Md5
from rust::sha1 @ "0.10" import Sha1
from rust::sha2 @ "0.10" import Digest, Sha224, Sha256, Sha384, Sha512
from rust::sha3 @ "0.10" import Sha3_224, Sha3_256, Sha3_384, Sha3_512, Shake128, Shake256
from rust::sha3::digest @ "0.10" import ExtendableOutputReset, Update, XofReader
from rust::xxhash_rust::xxh3 @ "0.8" with ["xxh3"] import Xxh3Default
from rust::xxhash_rust::xxh32 @ "0.8" with ["xxh32"] import Xxh32
from rust::xxhash_rust::xxh64 @ "0.8" with ["xxh64"] import Xxh64
from std.traits.error import Error


pub const DEFAULT_CHUNK_SIZE: int = 65536


@derive(Clone)
pub model HashError with Error:
    """
    Stable error value returned by fallible `std.hash` helpers.

    `algorithm` is the requested hash name, `kind` is the branchable error category, and `detail` is the
    human-readable message. One-shot namespace helpers raise `ValueError` for this detail when their API is infallible.
    """

    pub kind: str
    pub algorithm: str
    pub detail: str

    def message(self) -> str:
        """
        Return the human-readable failure detail.
        """
        return self.detail

    def source(self) -> Option[str]:
        """
        Hash errors currently do not wrap structured source errors.
        """
        return None


pub trait ByteDigestHasher:
    """
    Incremental byte-digest hasher contract used by fixed-length digest algorithms.
    """

    def update(mut self, chunk: bytes) -> None: ...

    def finalize_bytes(mut self) -> bytes: ...


pub trait ShakeDigestHasher:
    """
    Incremental SHAKE hasher contract with caller-selected output length.
    """

    def update(mut self, chunk: bytes) -> None: ...

    def finalize_bytes(mut self, length: int) -> Result[bytes, HashError]: ...


pub trait Hash32DigestHasher:
    """
    Incremental non-cryptographic hasher contract for algorithms with native `u32` output.
    """

    def update(mut self, chunk: bytes) -> None: ...

    def finalize_bytes(mut self) -> bytes: ...

    def finalize_u32(mut self) -> u32: ...


pub trait Hash64DigestHasher:
    """
    Incremental non-cryptographic hasher contract for algorithms with native `u64` output.
    """

    def update(mut self, chunk: bytes) -> None: ...

    def finalize_bytes(mut self) -> bytes: ...

    def finalize_u64(mut self) -> u64: ...


pub trait Hash128DigestHasher:
    """
    Incremental non-cryptographic hasher contract for algorithms with native `u128` output.
    """

    def update(mut self, chunk: bytes) -> None: ...

    def finalize_bytes(mut self) -> bytes: ...

    def finalize_u128(mut self) -> u128: ...


pub enum _Algorithm(str):
    """
    Canonical algorithm selector used after validating public string names.

    Public file and reader helpers accept strings to keep the RFC surface compact. Internally, dispatch converts those
    strings once and then matches on this enum so unsupported names and unsupported output widths stay distinct.
    """

    Sha224 = "sha224"
    Sha256 = "sha256"
    Sha384 = "sha384"
    Sha512 = "sha512"
    Sha3_224 = "sha3_224"
    Sha3_256 = "sha3_256"
    Sha3_384 = "sha3_384"
    Sha3_512 = "sha3_512"
    Shake128 = "shake128"
    Shake256 = "shake256"
    Blake2b = "blake2b"
    Blake2s = "blake2s"
    Blake3 = "blake3"
    Md5 = "md5"
    Sha1 = "sha1"
    Xxh32 = "xxh32"
    Xxh64 = "xxh64"
    Xxh3_64 = "xxh3_64"
    Xxh3_128 = "xxh3_128"

    def from_str(name: str) -> Result[Self, HashError]:
        """
        Parse a public algorithm name into the internal selector.

        Args:
            name: Canonical algorithm name such as `sha256`, `blake3`, or `xxh3_128`.

        Returns:
            `Ok(_Algorithm)` for known names, or `Err(HashError)` with kind `unknown_algorithm`.
        """
        if let Some(parsed) = _Algorithm.from_value(name):
            return Ok(parsed)
        return Err(_invalid_error(name, "unknown_algorithm", f"unknown hash algorithm: {name}"))

    def is_known(name: str) -> bool:
        """
        Return whether `name` is a known hash algorithm.
        """
        known = _Algorithm.from_str(name).map((_algorithm) => true).map_err((_error) => false)
        match known:
            Ok(value) => return value
            Err(value) => return value

    def name(self) -> str:
        """
        Return the canonical public algorithm name.
        """
        return self.value()

    def is_shake(self) -> bool:
        """
        Return whether this algorithm has caller-selected SHAKE output length.
        """
        match self:
            _Algorithm.Shake128 => return true
            _Algorithm.Shake256 => return true
            _ => return false


pub class _Sha224Hasher with ByteDigestHasher:
    """
    Incremental SHA-224 hasher.
    """

    handle: Sha224

    def update(mut self, chunk: bytes) -> None:
        Digest.update(self.handle, chunk.as_slice())

    def finalize_bytes(mut self) -> bytes:
        return self.handle.finalize_reset().to_vec()


