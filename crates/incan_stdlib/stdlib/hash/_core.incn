pub class _Xxh32Hasher with Hash32DigestHasher:
    """
    Incremental xxHash32 hasher with 32-bit output.
    """

    handle: Xxh32

    def update(mut self, chunk: bytes) -> None:
        self.handle.update(chunk.as_slice())

    def finalize_bytes(mut self) -> bytes:
        return _u32_to_le_bytes(self.finalize_u32())

    def finalize_u32(mut self) -> u32:
        return self.handle.digest()


