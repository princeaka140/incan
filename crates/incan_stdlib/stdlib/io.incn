def _read_i128_value(stream: _BytesIO, endian: Endian, operation: str) -> Result[i128, IoError]:
    mut cursor = Cursor.new(stream.read_exact(16)?)
    if endian == Endian.Little:
        match cursor.read_i128[LittleEndian]():
            Ok(value) => return Ok(value)
            Err(err) => return Err(_rust_io_error(operation, stream.tell(), err))
    match cursor.read_i128[BigEndian]():
        Ok(value) => return Ok(value)
        Err(err) => return Err(_rust_io_error(operation, stream.tell(), err))


def _write_u128_value(stream: _BytesIO, value: u128, endian: Endian, operation: str) -> Result[None, IoError]:
    mut cursor = Cursor.new(_zeros(16))
    if endian == Endian.Little:
        match cursor.write_u128[LittleEndian](value):
            Ok(_) => return _finish_numeric_write(stream, cursor)
            Err(err) => return Err(_rust_io_error(operation, stream.tell(), err))
    match cursor.write_u128[BigEndian](value):
        Ok(_) => return _finish_numeric_write(stream, cursor)
