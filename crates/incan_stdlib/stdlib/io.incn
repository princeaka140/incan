def _read_u128_value(stream: _BytesIO, endian: Endian, operation: str) -> Result[u128, IoError]:
    mut cursor = Cursor.new(stream.read_exact(16)?)
    if endian == Endian.Little:
        match cursor.read_u128[LittleEndian]():
