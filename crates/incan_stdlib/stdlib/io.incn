def _truncate_target_usize(target: int, position: int) -> Result[usize, IoError]:
    """
    Convert a validated truncate target into the host vector size type.
    """
    maybe_target: Option[usize] = target.try_resize()
    match maybe_target:
        Some(value) => return Ok(value)
        None => return Err(_invalid_input("truncate", position, "truncate size does not fit host usize"))


def _truncate_target_u64(target: int, position: int) -> Result[u64, IoError]:
    """
    Convert a validated truncate target into the cursor position type.
    """
    maybe_target: Option[u64] = target.try_resize()
    match maybe_target:
        Some(value) => return Ok(value)
        None => return Err(_invalid_input("truncate", position, "truncate size does not fit u64"))


def _invalid_input(operation: str, position: int, detail: str) -> IoError:
    """
    Create a stable invalid-input error.
    """
    return IoError(operation=operation, kind="invalid_input", detail=detail, position=position)


def _rust_io_error(operation: str, position: int, detail: str) -> IoError:
    """
    Convert host I/O error text into a `std.io` error.
    """
    if detail.contains("invalid"):
        return IoError(operation=operation, kind="invalid_input", detail=detail, position=position)
    elif detail.contains("failed to fill whole buffer") or detail.contains("early eof"):
        return IoError(operation=operation, kind="unexpected_eof", detail=detail, position=position)
    return IoError(operation=operation, kind="other", detail=detail, position=position)
