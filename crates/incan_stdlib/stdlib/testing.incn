rust.module("incan_stdlib::testing")

"""
Incan Testing Framework

A pytest-like testing library for Incan.

Example:

```incan
from std.testing import fixture, parametrize, skip, test, xfail

@fixture
def database() -> Database:
    return Database.connect("test.db")

@parametrize("a, b, expected", [
    (1, 2, 3),
    (0, 0, 0),
])
def test_add(a: int, b: int, expected: int) -> None:
    assert_eq(add(a, b), expected)

@skip("not implemented")
def test_future() -> None:
    pass
```

Marker semantics are declared on marker APIs via `@rust.extern(metadata={...})`.
`incan test` consumes that metadata from this module as the source of truth.
"""

# =============================================================================
# Test Utilities
# =============================================================================

pub def fail(msg: str) -> None:
    """Explicitly fail a test with a message.

    Fail makes the program raise a panic.

    Example:
    
    ```incan
    fail("this test should not reach here")
    ```
    """
    return fail_t(msg)


@rust.extern
pub def fail_t[T](msg: str) -> T:
    """Generic failure primitive for helper functions returning `T`.

    This always fails by delegating to the host panic boundary, but has a generic return type so assertion helpers -
    like `assert_is_some()` - can typecheck cleanly.

    Example:

    ```incan
    return fail_t("assertion failed")
    ```
    """
    ...

# =============================================================================
# Markers
# =============================================================================

@rust.extern(metadata={"marker_kind": "skip", "runner_only": true})
pub def skip(reason: str = "") -> None:
    """
    Skip a test unconditionally.

    Example:

    ```incan
    @skip("not implemented yet")
    def test_future_feature() -> None:
        pass
    ```

    Note: Marker decorators are consumed by `incan test` during discovery.
          Their runtime implementation stays a host boundary so metadata remains parseable in this declaration surface.
    """
    ...


@rust.extern(metadata={"marker_kind": "test", "runner_only": true})
pub def test() -> None:
    """
    Mark a function as a test even when its name does not start with `test_`.

    Example:

    ```incan
    @test
    def checks_total() -> None:
        assert_eq(total(), 42)
    ```

    Note: Marker decorators are consumed by `incan test` during discovery.
          Their runtime implementation stays a host boundary so metadata remains parseable in this declaration surface.
    """
    ...


@rust.extern(metadata={"marker_kind": "skipif", "runner_only": true})
pub def skipif(condition: bool, reason: str = "") -> None:
    """
    Skip a test when a collection-time condition is true.

    Supported conditions are literals, boolean operators, string equality against `platform()`, and `feature("name")`.
    """
    ...


@rust.extern(metadata={"marker_kind": "xfail", "runner_only": true})
pub def xfail(reason: str = "") -> None:
    """
    Mark a test as expected to fail.

    The test runs but failure is not reported as an error.
    If the test passes unexpectedly, it's reported as XPASS.

    Example:

    ```incan
    @xfail("known bug #123")
    def test_known_issue() -> None:
        assert broken_function() == "fixed"
    ```

    Note: Marker decorators are consumed by `incan test` during discovery.
          Their runtime implementation stays a host boundary so metadata remains parseable in this declaration surface.
    """
    ...


@rust.extern(metadata={"marker_kind": "xfailif", "runner_only": true})
pub def xfailif(condition: bool, reason: str = "") -> None:
    """
    Expect a test to fail when a collection-time condition is true.

    Supported conditions are literals, boolean operators, string equality against `platform()`, and `feature("name")`.
    """
    ...


@rust.extern
pub def platform() -> str:
    """
    Return the platform name used by collection-time testing marker probes.

    `incan test` evaluates this during collection; runtime calls return the host OS identifier.
    """
    ...


@rust.extern
pub def feature(name: str) -> bool:
    """
    Return whether an `incan test --feature <name>` collection feature is enabled.

    Runtime calls return false because collection features are runner metadata, not application configuration.
    """
    ...


@rust.extern(metadata={"marker_kind": "slow", "runner_only": true})
pub def slow() -> None:
    """
    Mark a test as slow.

    Slow tests are excluded by default. Run with --slow to include.

    Example:

    ```incan
    @slow
    def test_integration() -> None:
        # Long-running test
        pass
    ```

    Note: Marker decorators are consumed by `incan test` during discovery.
          Their runtime implementation stays a host boundary so metadata remains parseable in this declaration surface.
    """
    ...


@rust.extern(metadata={"marker_kind": "mark", "runner_only": true})
pub def mark(name: str) -> None:
    """
    Attach a named marker to a test for `incan test -m` selection.

    Marker names should use snake_case. With `--strict-markers`, names must be registered by TEST_MARKERS.
    """
    ...


@rust.extern(metadata={"marker_kind": "resource", "runner_only": true})
pub def resource(name: str) -> None:
    """
    Attach resource metadata to a test.

    `incan test --jobs N` will not overlap tests that share the same resource key.
    """
    ...


@rust.extern(metadata={"marker_kind": "serial", "runner_only": true})
pub def serial() -> None:
    """
    Attach serial-execution metadata to a test.

    `incan test --jobs N` runs serial tests alone against all other scheduled units.
    """
    ...


@rust.extern(metadata={"marker_kind": "timeout", "runner_only": true})
pub def timeout(duration: str) -> None:
    """
    Set the timeout used for the generated test batch that contains this test, such as "250ms", "5s", or "2m".
    """
    ...


# =============================================================================
# Fixtures
# =============================================================================

@rust.extern(metadata={
    "marker_kind": "fixture",
    "runner_only": true,
    "scope_arg": "scope",
    "autouse_arg": "autouse",
    "scopes": ["function", "module", "session"],
})
pub def fixture() -> None:
    """
    Mark a function as a test fixture.

    Fixtures provide setup values and dependency injection for tests. Function scope runs per test. Module/session
    scopes are cached inside the generated per-file test harness process. One top-level `yield` statement splits setup
    from teardown for function-scoped fixtures; teardown code cannot reference setup locals or fixture parameters in the
    current runner transform.

    Example:

    ```incan
    @fixture
    def temp_name() -> str:
        return "scratch.txt"

    def test_write(temp_name: str) -> None:
        assert temp_name == "scratch.txt"
    ```

    Note: Fixtures are injected by parameter name matching.
    """
    ...


# =============================================================================
# Parametrize
# =============================================================================

@rust.extern(metadata={"marker_kind": "parametrize", "runner_only": true})
pub def parametrize[T](argnames: str, argvalues: List[T]) -> None:
    """
    Run a test with multiple parameter sets.

    Example:

    ```incan
    @parametrize("x, y, expected", [
        (1, 2, 3),
        (0, 0, 0),
        (-1, 1, 0),
        (100, 200, 300),
    ])
    def test_add(x: int, y: int, expected: int) -> None:
        assert add(x, y) == expected
    ```

    This generates:

    ```bash
    test_add[1-2-3] ... PASSED
    test_add[0-0-0] ... PASSED
    test_add[-1-1-0] ... PASSED
    test_add[100-200-300] ... PASSED
    ```
    """
    ...


@rust.extern
pub def param_case[T](value: T, marks: List[str] = [], id: str = "") -> T:
    """
    Attach metadata to one parameter set inside `parametrize`.
    """
    ...


# =============================================================================
# Assertion Helpers (optional, prefer plain assert)
# =============================================================================

pub def assert(condition: bool, msg: str = "assertion failed") -> None:
    """Assert condition is true.

    Example:

    ```incan
    assert(False, "This test will fail with this message")
    ```

    Note: Prefer plain `assert left == right` for most cases.
    """
    if not condition:
        fail(msg)


pub def assert_eq[T](left: T, right: T, msg: str = "assertion failed: left != right") -> None:
    """
    Assert two values are equal.

    Prefer plain `assert left == right` for most cases.

    Example:

    ```incan
    assert_eq(result, expected, "calculation was wrong")
    ```
    """
    if left != right:
        fail(msg)


pub def assert_ne[T](left: T, right: T, msg: str = "assertion failed: left == right") -> None:
    """Assert two values are not equal."""
    if left == right:
        fail(msg)


pub def assert_true(condition: bool, msg: str = "assertion failed: expected true") -> None:
    """Assert condition is true."""
    if not condition:
        fail(msg)


pub def assert_false(condition: bool, msg: str = "assertion failed: expected false") -> None:
    """Assert condition is false."""
    if condition:
        fail(msg)


pub def assert_is_some[T](option: Option[T], msg: str = "assertion failed: expected Some, got None") -> T:
    """
    Assert Option is Some and return the value.

    Example:

    ```incan
    value = assert_is_some(get_user(id))
    assert value.name == "Alice"
    ```
    """
    match option:
        Some(value) => return value
        None => return fail_t(msg)


pub def assert_is_none[T](option: Option[T], msg: str = "assertion failed: expected None, got Some") -> None:
    """Assert Option is None."""
    match option:
        Some(_) => fail(msg)
        None => return


pub def assert_is_ok[T, E](result: Result[T, E], msg: str = "assertion failed: expected Ok, got Err") -> T:
    """
    Assert Result is Ok and return the value.

    Example:

    ```incan
    user = assert_is_ok(fetch_user(id))
    assert user.active
    ```
    """
    match result:
        Ok(value) => return value
        Err(_) =>
            return fail_t(msg)


pub def assert_is_err[T, E](result: Result[T, E], msg: str = "assertion failed: expected Err, got Ok") -> E:
    """Assert Result is Err and return the error."""
    match result:
        Err(err) => return err
        Ok(_) => return fail_t(msg)

pub def assert_raises[E](block: () -> None, msg: str = "") -> None:
    """
    Assert that a zero-argument block raises/panics with error type E.

    The compiler recognizes this helper at call sites and emits runtime panic-payload matching.

    Example:

    ```incan
    def bad_parse() -> None:
        int("not a number")

    assert_raises[ValueError](bad_parse)
    ```
    """
    # Compiler-recognized helper calls are emitted before this fallback body is used.
    if msg == "":
        return fail_t("std.testing.assert_raises requires compiler lowering")
    return fail_t(msg)
