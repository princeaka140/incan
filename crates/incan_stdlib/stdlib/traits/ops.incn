    MatMul trait - Enables `a @ b` for custom types
    Python equivalent: __matmul__
    """
    def __matmul__(self, other: Rhs) -> Output: ...


trait MatMulAssign[Rhs, Output]:
    """
    MatMulAssign trait - Enables an explicit `a @= b` hook for custom types
    Python equivalent: __imatmul__

