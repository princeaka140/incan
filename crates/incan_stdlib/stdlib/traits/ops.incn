trait GetItem[Key, Output]:
    """
    GetItem trait - Enables `obj[key]` read access for custom types
    Python equivalent: __getitem__
    """
    def __getitem__(self, key: Key) -> Output: ...


trait SetItem[Key, Value]:
    """
    SetItem trait - Enables `obj[key] = value` write access for custom types
    Python equivalent: __setitem__
    """
    def __setitem__(self, key: Key, value: Value) -> None: ...
