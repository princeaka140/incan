"""Issue #196: infer generic bounds required by trait return types."""

pub trait DataSet[T with Clone]:
    def tag(self) -> T: ...


pub trait BoundedDataSet[T with Clone] with DataSet[T]:
    def bound(self) -> T: ...


pub def upcast_bounded_to_dataset[T](value: BoundedDataSet[T]) -> DataSet[T]:
    return value


pub def upcast_bounded_to_bounded[T](value: BoundedDataSet[T]) -> BoundedDataSet[T]:
    return value


def main() -> None:
    pass
