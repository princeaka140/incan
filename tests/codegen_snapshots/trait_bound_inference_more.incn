# RFC 023: Trait bound inference - additional cases
#
# Covers:
# - f-string interpolation -> Display
# - Dict literal with generic key -> Eq + Hash
# - arithmetic operators: +, -, *, /, % -> Add/Sub/Mul/Div/Rem<Output = T>
# - clone() method call -> Clone
# - transitive inference across generic function calls
# - combined explicit + inferred bounds

def show[T](x: T) -> str:
    return f"{x}"

def make_dict[T](k: T) -> Dict[T, int]:
    return {k: 1}

def add[T](a: T, b: T) -> T:
    return a + b

def subtract[T](a: T, b: T) -> T:
    return a - b

def multiply[T](a: T, b: T) -> T:
    return a * b

def divide[T](a: T, b: T) -> T:
    return a / b

def modulo[T](a: T, b: T) -> T:
    return a % b

def duplicate[T](x: T) -> T:
    return x.clone()

def are_equal[T](left: T, right: T) -> bool:
    return left == right

def wrapper[T](a: T, b: T) -> bool:
    return are_equal(a, b)

def show_eq[T with Eq](x: T) -> str:
    return f"{x}"

def main() -> None:
    pass
