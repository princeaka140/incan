"""Issue #367: `Ok("...")` in `Result[str, E]` contexts should emit owned `String`."""

def takes_result(value: Result[str, str]) -> None:
    match value:
        case Ok(msg):
            println(msg)
        case Err(err):
            println(err)

def returns_result() -> Result[str, str]:
    return Ok("from_return")

def main() -> None:
    direct: Result[str, str] = Ok("from_local")
    match direct:
        case Ok(msg):
            println(msg)
        case Err(err):
            println(err)
    takes_result(Ok("from_call"))
    result: Result[str, str] = returns_result()
    match result:
        case Ok(msg):
            println(msg)
        case Err(err):
            println(err)
