from std.graph import DiGraph, Dag, MultiDiGraph, NodeId, EdgeId, GraphError

def exercise_graphs() -> None:
    mut graph = DiGraph[str]()
    a: NodeId = graph.add_node("a")
    b: NodeId = graph.add_node("b")
    edge_result: Result[None, GraphError] = graph.add_edge(a, b)
    removed_edge: Result[None, GraphError] = graph.remove_edge(a, b)
    removed_node: Result[None, GraphError] = graph.remove_node(a)
    successors: Result[list[NodeId], GraphError] = graph.successors(b)
    predecessors: Result[list[NodeId], GraphError] = graph.predecessors(b)
    bfs: Result[list[NodeId], GraphError] = graph.bfs_nodes(b)
    dfs: Result[list[NodeId], GraphError] = graph.dfs_preorder_nodes(b)
    topo: Result[list[NodeId], GraphError] = graph.topological_order()
    roots: list[NodeId] = graph.roots()
    sinks: list[NodeId] = graph.sinks()

    mut dag = Dag[str]()
    root: NodeId = dag.add_node("root")
    leaf: NodeId = dag.add_node("leaf")
    dag_edge: Result[None, GraphError] = dag.add_edge(root, leaf)
    dag_order: list[NodeId] = dag.topological_order()

    mut multi = MultiDiGraph[str]()
    left: NodeId = multi.add_node("left")
    right: NodeId = multi.add_node("right")
    multi_edge: Result[EdgeId, GraphError] = multi.add_edge(left, right)
    edges: Result[list[EdgeId], GraphError] = multi.edges_between(left, right)
    multi_topo: Result[list[NodeId], GraphError] = multi.topological_order()

def main() -> None:
    exercise_graphs()
