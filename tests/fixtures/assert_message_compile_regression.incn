"""
Regression: std.testing message-bearing assertion calls should compile.
"""

from std.testing import assert_eq, assert_ne, assert_true, assert_false


def main() -> None:
    assert_true(True, "assert_true with message")
    assert_false(False, "assert_false with message")
    assert_eq(1, 1, "assert_eq with message")
    assert_ne(1, 2, "assert_ne with message")
