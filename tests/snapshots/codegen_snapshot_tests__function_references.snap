fn double(x: i64) -> i64 {
    return x * 2;
}
fn square(x: i64) -> i64 {
    return x * x;
}
fn apply_transform(func: fn(i64) -> i64, value: i64) -> i64 {
    return func(value);
}
fn test_function_references() -> (i64, i64) {
    let doubled = apply_transform(double, 5);
    let squared = apply_transform(square, 3);
    return (doubled, squared);
}
fn map_list(items: Vec<i64>, transformer: fn(i64) -> i64) -> Vec<i64> {
    let mut result = vec![];
    for item in items.iter().copied() {
        result.push(transformer(item));
    }
    return result.clone();
}
fn test_callable_syntax() -> Vec<i64> {
    let nums = vec![1, 2, 3];
    let mut doubled_arrows = map_list(nums.clone(), double.clone());
    let doubled_callable = map_list(nums, double);
    for item in doubled_callable.iter().copied() {
        doubled_arrows.push(item);
    }
    return doubled_arrows.clone();
}
