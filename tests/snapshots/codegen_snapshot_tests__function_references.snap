    return x + y;
}
fn multiply(x: i64, y: i64) -> i64 {
    return x * y;
}
fn test_multi_param() -> (i64, i64) {
    let sum_result = apply_binary(add, 3, 4);
    let product_result = apply_binary(multiply, 3, 4);
    return (sum_result, product_result);
}
