// Generated by the Incan compiler v<INCAN_VERSION>

// __INCAN_INSERT_MODS__

incan_stdlib::__incan_stdlib_version_check!("<INCAN_STDLIB_VERSION>");
#[derive(Clone, Debug, incan_derive::FieldInfo, incan_derive::IncanClass)]
struct StoredNode {
    store_id_raw: i64,
    node: String,
}
fn store_nodes(store_id: i64, stored_nodes: Vec<StoredNode>) -> Vec<String> {
    return (stored_nodes)
        .iter()
        .filter_map(|stored| {
            let stored = (*stored).clone();
            if stored.store_id_raw == store_id { Some(stored.node) } else { None }
        })
        .collect::<Vec<_>>();
}
fn main() {
    std::panic::set_hook(
        std::boxed::Box::new(|panic_info| {
            if let Some(message) = panic_info.payload().downcast_ref::<&str>() {
                eprintln!("{message}");
            } else if let Some(message) = panic_info.payload().downcast_ref::<String>() {
                eprintln!("{message}");
            } else {
                eprintln!("generated program panicked");
            }
        }),
    );
    let nodes = vec![
        StoredNode { store_id_raw : 1, node : "a".to_string() }, StoredNode {
        store_id_raw : 2, node : "b".to_string() }
    ];
    println!(
        "{}", incan_stdlib::collections::list_get(& store_nodes(1, nodes), (0) as i64)
        .clone()
    );
}
