// Generated by the Incan compiler v<INCAN_VERSION>

// __INCAN_INSERT_MODS__

incan_stdlib::__incan_stdlib_version_check!("<INCAN_STDLIB_VERSION>");
fn test_match_simple() {
    let x = 42;
    match x {
        0 => {
            println!("{}", "zero");
        }
        1 => {
            println!("{}", "one");
        }
        _ => {
            println!("{}", "other");
        }
    };
}
fn test_match_with_option() {
    let value = Some(42);
    match value {
        Some(n) => {
            println!("{}", n);
        }
        None => {
            println!("{}", "nothing");
        }
    };
}
fn test_match_multiple_patterns() {
    let x = 5;
    match x {
        1 => {
            println!("{}", "one");
        }
        2 => {
            println!("{}", "two");
        }
        3 => {
            println!("{}", "three");
        }
        _ => {
            println!("{}", "many");
        }
    };
}
fn test_match_with_guard() {
    let x = 15;
    match x {
        n if n < 10 => {
            println!("{}", "small");
        }
        n if n < 20 => {
            println!("{}", "medium");
        }
        _ => {
            println!("{}", "large");
        }
    };
}
fn main() {
    std::panic::set_hook(
        std::boxed::Box::new(|panic_info| {
            if let Some(message) = panic_info.payload().downcast_ref::<&str>() {
                eprintln!("{message}");
            } else if let Some(message) = panic_info.payload().downcast_ref::<String>() {
                eprintln!("{message}");
            } else {
                eprintln!("generated program panicked");
            }
        }),
    );
    test_match_simple();
    test_match_with_option();
    test_match_multiple_patterns();
    test_match_with_guard();
}
