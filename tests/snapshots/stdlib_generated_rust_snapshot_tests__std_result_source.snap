/// Transform an `Ok(T)` payload.
///
/// Args:
///     result: Result to inspect.
///     f: Function called with the `Ok(T)` payload.
///
/// Returns:
///     `Ok(f(value))` when `result` is `Ok(value)`, otherwise the original `Err(E)`.
pub fn map<T, E, U>(result: Result<T, E>, f: fn(T) -> U) -> Result<U, E> {
    "\n    Transform an `Ok(T)` payload.\n\n    Args:\n        result: Result to inspect.\n        f: Function called with the `Ok(T)` payload.\n\n    Returns:\n        `Ok(f(value))` when `result` is `Ok(value)`, otherwise the original `Err(E)`.\n    ";
    match result {
        Ok(value) => {
            return Ok::<U, E>(f(value));
        }
        Err(error) => {
            return Err::<U, E>(error);
        }
    };
}
