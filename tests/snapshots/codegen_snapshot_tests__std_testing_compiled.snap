pub fn param_case<T>(value: T, marks: Vec<String>, id: String) -> T {
    incan_stdlib::testing::param_case::<T>(value, marks, id)
}
/// Assert condition is true.
///
/// Example:
///
/// ```ignore
/// assert(False, "This test will fail with this message")
/// ```
///
/// Note: Prefer plain `assert left == right` for most cases.
pub fn assert(condition: bool, msg: String) {
    "Assert condition is true.\n\n    Example:\n\n    ```incan\n    assert(False, \"This test will fail with this message\")\n    ```\n\n    Note: Prefer plain `assert left == right` for most cases.\n    ";
    if !condition {
        fail(msg);
    }
}
/// Assert two values are equal.
///
/// Prefer plain `assert left == right` for most cases.
///
/// Example:
///
/// ```ignore
/// assert_eq(result, expected, "calculation was wrong")
/// ```
pub fn assert_eq<T: PartialEq>(left: T, right: T, msg: String) {
    "\n    Assert two values are equal.\n\n    Prefer plain `assert left == right` for most cases.\n\n    Example:\n\n    ```incan\n    assert_eq(result, expected, \"calculation was wrong\")\n    ```\n    ";
    if left != right {
        fail(msg);
    }
}
/// Assert two values are not equal.
pub fn assert_ne<T: PartialEq>(left: T, right: T, msg: String) {
    "Assert two values are not equal.";
    if left == right {
        fail(msg);
    }
}
