pub fn assert(condition: bool, msg: String) {
    "Assert condition is true.\n\n    Example:\n\n    ```incan\n    assert(False, \"This test will fail with this message\")\n    ```\n\n    Note: Prefer plain `assert left == right` for most cases.\n    ";
    if !condition {
        fail(msg);
    }
}
pub fn assert_eq<T: PartialEq>(left: T, right: T, msg: String) {
    "\n    Assert two values are equal.\n\n    Prefer plain `assert left == right` for most cases.\n\n    Example:\n\n    ```incan\n    assert_eq(result, expected, \"calculation was wrong\")\n    ```\n    ";
    if left != right {
        fail(msg);
    }
}
pub fn assert_ne<T: PartialEq>(left: T, right: T, msg: String) {
    "Assert two values are not equal.";
    if left == right {
        fail(msg);
    }
}
pub fn assert_true(condition: bool, msg: String) {
    "Assert condition is true.";
    assert(condition, msg);
}
pub fn assert_false(condition: bool, msg: String) {
    "Assert condition is false.";
    assert(!condition, msg);
}
pub fn assert_is_some<T>(option: Option<T>, msg: String) -> T {
    "\n    Assert Option is Some and return the value.\n\n    Example:\n\n    ```incan\n    value = assert_is_some(get_user(id))\n    assert value.name == \"Alice\"\n    ```\n    ";
    match option {
        Some(value) => {
            return value;
        }
        None => {
            return fail_t(msg);
        }
    };
}
pub fn assert_is_none<T>(option: Option<T>, msg: String) {
    "Assert Option is None.";
    match option {
        Some(_) => fail(msg),
        None => {
            return;
        }
    };
}
pub fn assert_is_ok<T, E>(result: Result<T, E>, msg: String) -> T {
    "\n    Assert Result is Ok and return the value.\n\n    Example:\n\n    ```incan\n    user = assert_is_ok(fetch_user(id))\n    assert user.active\n    ```\n    ";
    match result {
        Ok(value) => {
            return value;
        }
        Err(_) => {
            return fail_t(msg);
        }
    };
}
pub fn assert_is_err<T, E>(result: Result<T, E>, msg: String) -> E {
    "Assert Result is Err and return the error.";
    match result {
        Err(err) => {
            return err;
        }
        Ok(_) => {
            return fail_t(msg);
        }
    };
}
pub fn assert_raises<E>(block: fn() -> (), msg: String) -> E {
    incan_stdlib::testing::assert_raises::<E>(block, msg)
