/// Assert Option is Some and return the value.
///
/// Example:
///
/// ```ignore
/// value = assert_is_some(get_user(id))
/// assert value.name == "Alice"
/// ```
pub fn assert_is_some<T>(option: Option<T>, msg: String) -> T {
    "\n    Assert Option is Some and return the value.\n\n    Example:\n\n    ```incan\n    value = assert_is_some(get_user(id))\n    assert value.name == \"Alice\"\n    ```\n    ";
    match option {
        Some(value) => {
            return value;
        }
        None => {
            return fail_t(msg);
        }
    };
}
/// Assert Option is None.
pub fn assert_is_none<T>(option: Option<T>, msg: String) {
    "Assert Option is None.";
    match option {
        Some(_) => fail(msg),
        None => {
            return;
        }
    };
}
/// Assert Result is Ok and return the value.
///
/// Example:
///
/// ```ignore
/// user = assert_is_ok(fetch_user(id))
/// assert user.active
/// ```
pub fn assert_is_ok<T, E>(result: Result<T, E>, msg: String) -> T {
    "\n    Assert Result is Ok and return the value.\n\n    Example:\n\n    ```incan\n    user = assert_is_ok(fetch_user(id))\n    assert user.active\n    ```\n    ";
    match result {
        Ok(value) => {
            return value;
        }
        Err(_) => {
            return fail_t(msg);
        }
    };
}
/// Assert Result is Err and return the error.
pub fn assert_is_err<T, E>(result: Result<T, E>, msg: String) -> E {
    "Assert Result is Err and return the error.";
    match result {
        Err(err) => {
            return err;
        }
        Ok(_) => {
            return fail_t(msg);
        }
    };
}
/// Assert that a zero-argument block raises/panics with error type E.
///
/// The compiler recognizes this helper at call sites and emits runtime panic-payload matching.
///
/// Example:
///
/// ```ignore
/// def bad_parse() -> None:
///     int("not a number")
///
/// assert_raises[ValueError](bad_parse)
/// ```
pub fn assert_raises<E>(_: fn() -> (), msg: String) {
    "\n    Assert that a zero-argument block raises/panics with error type E.\n\n    The compiler recognizes this helper at call sites and emits runtime panic-payload matching.\n\n    Example:\n\n    ```incan\n    def bad_parse() -> None:\n        int(\"not a number\")\n\n    assert_raises[ValueError](bad_parse)\n    ```\n    ";
    if incan_stdlib::strings::str_eq(&msg, &"") {
        return fail_t(
            "std.testing.assert_raises requires compiler lowering".to_string(),
        );
    }
    return fail_t(msg);
}
