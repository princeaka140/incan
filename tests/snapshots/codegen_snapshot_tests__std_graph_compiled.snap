                format!("{}", from_.to_int()), format!("{}", to.to_int())
            ];
            incan_stdlib::strings::fstring(&__parts, &__args)
        },
    };
}
fn missing_edge(from_: NodeId, to: NodeId) -> GraphError {
    return GraphError {
        detail: {
            let __parts: [&str; 3usize] = ["graph edge does not exist: ", " -> ", ""];
            let __args: Vec<String> = vec![
                format!("{}", from_.to_int()), format!("{}", to.to_int())
            ];
            incan_stdlib::strings::fstring(&__parts, &__args)
        },
    };
}
