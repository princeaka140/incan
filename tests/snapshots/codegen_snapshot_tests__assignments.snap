    let mut numbers: Vec<i64> = vec![1, 2, 3, 4];
    *incan_stdlib::collections::list_get_mut(&mut numbers, (0) as i64) = 10;
    *incan_stdlib::collections::list_get_mut(&mut numbers, (-1) as i64) = 40;
