// Generated by the Incan compiler v<INCAN_VERSION>

// __INCAN_INSERT_MODS__

incan_stdlib::__incan_stdlib_version_check!("<INCAN_STDLIB_VERSION>");
fn test_pattern_wildcard() {
    let x = 42;
    match x {
        _ => {
            println!("{}", "wildcard matches anything");
        }
    };
}
fn test_pattern_literals() {
    let value = 5;
    match value {
        0 => {
            println!("{}", "zero");
        }
        1 => {
            println!("{}", "one");
        }
        5 => {
            println!("{}", "five");
        }
        _ => {
            println!("{}", "other");
        }
    };
}
fn test_pattern_string_literal() {
    let name = "Alice".to_string();
    match name {
        "Alice" => {
            println!("{}", "Hello Alice");
        }
        "Bob" => {
            println!("{}", "Hello Bob");
        }
        _ => {
            println!("{}", "Hello stranger");
        }
    };
}
fn test_pattern_bool() {
    let flag = true;
    match flag {
        true => {
            println!("{}", "yes");
        }
        false => {
            println!("{}", "no");
        }
    };
}
fn test_pattern_option_some() {
    let maybe = Some(42);
    match maybe {
        Some(n) => {
            println!("{}", n);
        }
        None => {
            println!("{}", "nothing");
        }
    };
}
fn test_pattern_option_none() {
    let maybe = None::<_>;
    match maybe {
        Some(n) => {
            println!("{}", n);
        }
        None => {
            println!("{}", "nothing");
        }
    };
}
fn test_pattern_result_ok() {
    let result = Ok::<i64, String>(42);
    match result {
        Ok(value) => {
            println!("{}", value);
        }
        Err(error) => {
            println!("{}", error);
        }
    };
}
fn test_pattern_result_err() {
    let result = Err::<i64, String>(("failed").to_string());
    match result {
        Ok(value) => {
            println!("{}", value);
        }
        Err(error) => {
            println!("{}", error);
        }
    };
}
fn test_pattern_nested_option() {
    let nested = Some(Some(42));
    match nested {
        Some(Some(n)) => {
            println!("{}", n);
        }
        Some(None) => {
            println!("{}", "inner none");
        }
        None => {
            println!("{}", "outer none");
        }
    };
}
fn test_pattern_tuple() {
    let pair = (42, "answer".to_string());
    match pair {
        (0, _) => {
            println!("{}", "first is zero");
        }
        (_, "answer") => {
            println!("{}", "second is answer");
        }
        _ => {
            println!("{}", "something else");
        }
    };
}
fn test_pattern_multiple_bindings() {
    let value = Some(10);
    match value {
        Some(x) if x > 5 => {
            println!("{}", "large");
        }
        Some(x) => {
            println!("{}", "small");
        }
        None => {
            println!("{}", "none");
        }
    };
}
fn main() {
    std::panic::set_hook(
        std::boxed::Box::new(|panic_info| {
            if let Some(message) = panic_info.payload().downcast_ref::<&str>() {
                eprintln!("{message}");
            } else if let Some(message) = panic_info.payload().downcast_ref::<String>() {
                eprintln!("{message}");
            } else {
                eprintln!("generated program panicked");
            }
        }),
    );
    test_pattern_wildcard();
    test_pattern_literals();
    test_pattern_string_literal();
    test_pattern_bool();
    test_pattern_option_some();
    test_pattern_option_none();
    test_pattern_result_ok();
    test_pattern_result_err();
    test_pattern_nested_option();
    test_pattern_tuple();
    test_pattern_multiple_bindings();
}
