fn test_lowercase_types() {
    let _numbers: Vec<i64> = vec![1, 2, 3];
    let _data: std::collections::HashMap<String, i64> = [
        ("a".to_string(), 1),
        ("b".to_string(), 2),
    ]
        .into_iter()
        .collect::<std::collections::HashMap<_, _>>();
    let _unique: std::collections::HashSet<i64> = [1, 2, 3]
        .into_iter()
        .collect::<std::collections::HashSet<_>>();
    let _pair: (i64, String) = (42, "hello".to_string());
    let _maybe: Option<i64> = None::<i64>;
    println!("{}", "All lowercase types work!");
}
fn main() {
    std::panic::set_hook(
        std::boxed::Box::new(|panic_info| {
            if let Some(message) = panic_info.payload().downcast_ref::<&str>() {
                eprintln!("{message}");
            } else if let Some(message) = panic_info.payload().downcast_ref::<String>() {
                eprintln!("{message}");
            } else {
                eprintln!("generated program panicked");
            }
        }),
    );
    test_lowercase_types();
}
