# JSON Serialization traits - Serialize and Deserialize
# These enable json_stringify() and json_parse() functions
# Python equivalents: json.dumps(), json.loads()

trait Serialize:
    @rust.extern
    def to_json(self) -> str: ...


trait Deserialize:
    @rust.extern
    def from_json(json_str: str) -> Result[Self, str]: ...
